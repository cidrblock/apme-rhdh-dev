# Copy to .env and adjust if your clones live elsewhere.

# ansible-backstage-plugins @ prototype/apme (plugin source)
PLUGIN_REPO=${HOME}/github/ansible-backstage-plugins

# redhat-developer/rhdh-local checkout
RHDH_LOCAL=${HOME}/github/rhdh-local

# APME Gateway URL as seen FROM the RHDH container (not from the host).
# Podman: host.containers.internal
# Docker Desktop: host.docker.internal
APME_BASE_URL=http://host.containers.internal:8080

# Compose frontend (quote — value contains a space)
COMPOSE="podman compose"

# Optional: clone URLs used by make setup when checkouts are missing
RHDH_LOCAL_GIT=https://github.com/redhat-developer/rhdh-local.git
PLUGIN_REPO_GIT=https://github.com/ansible/ansible-backstage-plugins.git
PLUGIN_REPO_BRANCH=prototype/apme

# Optional: GitHub PAT for registering repos (public repos often work without it).
# Create at https://github.com/settings/tokens (repo scope for private repos).
# Leave unset/commented — do not set to empty string.
# GITHUB_TOKEN=ghp_...

# Do NOT configure real AAP OAuth for the default local loop.
# Self-service "Add repository" / Create always opens an AAP login popup.
# Use stock Create (no AAP): /create/templates/default/apme-register-git-repository
# Stub ansible.rhaap is already in configs/app-config.local.yaml.
# app-config also sets ansible.apme.useStockCreateForRegister: true.

# Optional: FE plugins for make sync-dev (default: backstage-apme)
# SYNC_DEV_PLUGINS="backstage-apme self-service"

# make react ports (defaults avoid native APME :3000 and RHDH Local :7007).
# If you change these, also edit configs/app-config.react.yaml to match.
# REACT_PORT=3001
# REACT_BACKEND_PORT=7008

# make react writes these automatically on first run (keeps Guest JWTs valid
# across restarts). You can set them yourself; do not commit real secrets.
# BACKEND_SECRET=
# AUTH_SIGNING_KEY=
